# Grafana Configuration Template
# This file is generated by ads-grafana-toolkit setup

[paths]
data = {{ data_path | default('/var/lib/grafana') }}
temp_data_files = {{ temp_data_path | default('/var/lib/grafana/tmp') }}
logs = {{ logs_path | default('/var/log/grafana') }}
plugins = {{ plugins_path | default('/var/lib/grafana/plugins') }}
provisioning = {{ provisioning_path | default('/etc/grafana/provisioning') }}

[server]
protocol = {{ protocol | default('http') }}
http_addr = {{ http_addr | default('0.0.0.0') }}
http_port = {{ http_port | default('3000') }}
domain = {{ domain | default('localhost') }}
enforce_domain = {{ enforce_domain | default('false') }}
root_url = {{ root_url | default('%(protocol)s://%(domain)s:%(http_port)s/') }}
serve_from_sub_path = {{ serve_from_sub_path | default('false') }}

[database]
type = {{ db_type | default('sqlite3') }}
host = {{ db_host | default('127.0.0.1:3306') }}
name = {{ db_name | default('grafana') }}
user = {{ db_user | default('root') }}
password = {{ db_password | default('') }}
path = {{ db_path | default('grafana.db') }}

[security]
admin_user = {{ admin_user | default('admin') }}
admin_password = {{ admin_password | default('admin') }}
secret_key = {{ secret_key | default('SW2YcwTIb9zpOOhoPsMm') }}
disable_gravatar = {{ disable_gravatar | default('false') }}
cookie_secure = {{ cookie_secure | default('false') }}

[users]
allow_sign_up = {{ allow_sign_up | default('false') }}
allow_org_create = {{ allow_org_create | default('false') }}
auto_assign_org = {{ auto_assign_org | default('true') }}
auto_assign_org_role = {{ auto_assign_org_role | default('Viewer') }}
default_theme = {{ default_theme | default('dark') }}

[auth.anonymous]
enabled = {{ anonymous_enabled | default('false') }}
org_name = {{ anonymous_org_name | default('Main Org.') }}
org_role = {{ anonymous_org_role | default('Viewer') }}

[smtp]
enabled = {{ smtp_enabled | default('false') }}
host = {{ smtp_host | default('localhost:25') }}
user = {{ smtp_user | default('') }}
password = {{ smtp_password | default('') }}
from_address = {{ smtp_from_address | default('admin@grafana.localhost') }}
from_name = {{ smtp_from_name | default('Grafana') }}

[alerting]
enabled = {{ alerting_enabled | default('true') }}
execute_alerts = {{ alerting_execute | default('true') }}

[metrics]
enabled = {{ metrics_enabled | default('true') }}
interval_seconds = {{ metrics_interval | default('10') }}

[log]
mode = {{ log_mode | default('console file') }}
level = {{ log_level | default('info') }}

[log.console]
level = {{ console_log_level | default('info') }}
format = {{ console_log_format | default('console') }}

[log.file]
level = {{ file_log_level | default('info') }}
format = {{ file_log_format | default('text') }}
log_rotate = {{ log_rotate | default('true') }}
max_lines = {{ log_max_lines | default('1000000') }}
max_size_shift = {{ log_max_size | default('28') }}
daily_rotate = {{ log_daily_rotate | default('true') }}
max_days = {{ log_max_days | default('7') }}

[plugins]
enable_alpha = {{ plugins_enable_alpha | default('false') }}
app_tls_skip_verify_insecure = {{ plugins_tls_skip_verify | default('false') }}
